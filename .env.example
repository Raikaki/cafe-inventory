# Copy to .env and adjust. Used by docker-compose and (optionally) local run.

# --- Database (local docker-compose) ---
DB_NAME=cafe_inventory
DB_PASSWORD=root

# --- Database (Aiven free MySQL — for cloud deploy) ---
# Aiven REQUIRES SSL and uses the existing "defaultdb"; do NOT use createDatabaseIfNotExist.
# Replace HOST and PORT with the values from the Aiven console (Connection information).
# DB_URL=jdbc:mysql://mysql-xxxxx.aivencloud.com:PORT/defaultdb?sslMode=REQUIRED&serverTimezone=UTC
# DB_USERNAME=avnadmin
# DB_PASSWORD=your-aiven-password
# DB_POOL_SIZE=3

# --- Security ---
# Base64 secret (min 32 bytes). Generate: openssl rand -base64 48
JWT_SECRET=Q2FmZUludmVudG9yeVN1cGVyU2VjcmV0S2V5Rm9ySldUU2lnbmluZzEyMzQ1Njc4OTA=

# --- Default admin (created on first start) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@cafe.local

# --- Server ---
PORT=8080
